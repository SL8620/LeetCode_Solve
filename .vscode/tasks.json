{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C++: build active file (g++)",
      "type": "shell",
      "command": "D:/MinGw64/MinGW/bin/g++.exe",
      "args": [
        "-std=c++17",
        "-O2",
        "-Wall",
        "-Wextra",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "C++: run active file",
      "type": "shell",
      "command": "${fileDirname}/${fileBasenameNoExtension}.exe",
      "options": {
        "cwd": "${fileDirname}"
      },
      "dependsOn": "C++: build active file (g++)",
      "problemMatcher": []
    }
  ]
}
